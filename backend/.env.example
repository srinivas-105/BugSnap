# --- Core (safe defaults work out of the box) ---
APP_SECRET_KEY=change-this-to-something-random-in-production
SQLITE_DB_PATH=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Platform (super) admin account, auto-seeded on first run ---
PLATFORM_ADMIN_EMAIL=owner@bugsnap.dev
PLATFORM_ADMIN_PASSWORD=BugSnapOwner123!
PLATFORM_ADMIN_NAME=BugSnap Founder

# --- Optional: Google Gemini for the AI report assistant ---
# Leave blank and BugSnap automatically falls back to a smart rule-based
# assistant that still asks clarifying questions and routes to the right
# project — the app works perfectly without this key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
